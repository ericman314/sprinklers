{
  "name": "sprinklers",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm --workspace @sprinklers/server run dev",
    "dev:client": "npm --workspace @sprinklers/client run dev",
    "build": "npm --workspace @sprinklers/client run build",
    "start": "npm --workspace @sprinklers/server run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
